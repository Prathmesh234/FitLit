[Unit]
Description=FitLit Gmail health notification check
After=network-online.target fitlit.service
Wants=network-online.target

[Service]
Type=oneshot
User=__FITLIT_USER__
WorkingDirectory=__FITLIT_ROOT__
EnvironmentFile=-__FITLIT_ROOT__/.env
Environment="PATH=__FITLIT_PATH__"
ExecStart=__UV_PATH__ run python -m fitlit.gmail_service run
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
