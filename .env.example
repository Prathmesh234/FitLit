# FitLit configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real tokens.

# --- Google Health API auth --------------------------------------------------
# Pick ONE of the two approaches below.
#
# (A) OAuth refresh (recommended for any unattended / 24-7 run). The service
#     mints fresh access tokens from a long-lived refresh token automatically.
#     1. Set the client id + secret from your Google Cloud OAuth client.
#     2. Run `uv run python -m fitlit.auth login` and follow the prompts to
#        capture the refresh token, then paste it below.
GOOGLE_HEALTH_CLIENT_ID=your-oauth-client-id
GOOGLE_HEALTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_HEALTH_REFRESH_TOKEN=your-refresh-token
#
# (B) Static access token — quick one-off testing only. Expires in ~1h and does
#     NOT self-renew; the service 401s after that. Leave unset if using (A).
# GOOGLE_HEALTH_ACCESS_TOKEN=paste-access-token-here

# 'me' resolves to the token's own user. Or set an explicit user id.
GOOGLE_HEALTH_USER=me

# Redirect URI used by `fitlit.auth login` — must match a URI registered on the
# OAuth client if it's a "Web application" type (Desktop-app clients don't need it).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765/callback

# --- Gmail notification service ---------------------------------------------
# Reuses the OAuth client ID/secret above, but requires a separate send-only
# refresh token. Enable Gmail API, then run:
#   uv run python scripts/oauth_capture.py --gmail
GMAIL_REFRESH_TOKEN=your-gmail-send-refresh-token
FITLIT_GMAIL_TO=you@gmail.com
# FITLIT_GMAIL_FROM_NAME=FitLit
# FITLIT_GMAIL_MORNING_FALLBACK_HOUR=12
# FITLIT_GMAIL_EVENING_FILL_HOUR=20

# --- Optional overrides (sensible defaults already in config.py) -------------
# GOOGLE_HEALTH_BASE_URL=https://health.googleapis.com
# GOOGLE_HEALTH_PAGE_SIZE=100
# GOOGLE_HEALTH_TIMEOUT=30

# Rate limit: Google Health rejects with 429 past ~120 req/min/user; stay under.
# GOOGLE_HEALTH_RATE_LIMIT_PER_MIN=100

# How often the orchestrator wakes to dispatch due fetchers (seconds).
# FITLIT_TICK_SECONDS=10

# --- Server / container ------------------------------------------------------
# HTTP bind. Azure (Container Apps / App Service) injects PORT; default 8000.
# HOST=0.0.0.0
# PORT=8000
# Run the API without the background scheduler (e.g. extra API-only replicas).
# FITLIT_RUN_SCHEDULER=true

# --- Persistence -------------------------------------------------------------
# Where SQLite DBs + scheduler state are written. Point at a mounted volume /
# Azure Files share in a container so data survives restarts.
# FITLIT_DATA_DIR=/app/data
# Set to DELETE when the data dir is an SMB/Azure Files share (WAL needs local
# disk or NFS). Leave as WAL on local/ephemeral disk.
# FITLIT_SQLITE_JOURNAL=WAL
